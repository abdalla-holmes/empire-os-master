# EmpireOS Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# Server Configuration
# =============================================================================
EMPIREOS_HOST=0.0.0.0
EMPIREOS_PORT=8000
EMPIREOS_LOG_LEVEL=info
EMPIREOS_ENV=development

# =============================================================================
# LLM Provider API Keys
# =============================================================================

# OpenAI (for GPT-4o, GPT-4o-mini, DALL-E, Whisper)
EMPIREOS_OPENAI_API_KEY=

# Anthropic (for Claude 3.5/4)
EMPIREOS_ANTHROPIC_API_KEY=

# Google Gemini 2.5 (for Gemini Pro, Flash, etc.)
EMPIREOS_GOOGLE_API_KEY=

# LM Studio (local models — no API key needed if running locally)
EMPIREOS_LMSTUDIO_BASE_URL=http://localhost:1234/v1

# =============================================================================
# Voice Pipeline
# =============================================================================

# ElevenLabs (premium TTS)
EMPIREOS_ELEVENLABS_API_KEY=
EMPIREOS_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Microsoft Edge TTS (free, no key needed)
# EMPIREOS_EDGE_TTS_ENABLED=true

# Piper TTS (local, no key needed)
EMPIREOS_PIPER_MODEL_PATH=./models/piper

# Whisper.cpp (local STT, no key needed)
EMPIREOS_WHISPER_MODEL_PATH=./models/whisper

# =============================================================================
# Vision System
# =============================================================================

# Screen capture FPS (1-30)
EMPIREOS_VISION_FPS=5

# Privacy blocklist (comma-separated app names)
EMPIREOS_VISION_BLOCKLIST=1Password,Keychain Access,bank

# =============================================================================
# Computer Control
# =============================================================================

# Safety confirmation timeout (seconds)
EMPIREOS_CONTROL_CONFIRM_TIMEOUT=30

# Maximum actions per minute
EMPIREOS_CONTROL_RATE_LIMIT=60

# =============================================================================
# Website Generator
# =============================================================================

# Vercel Token (for deployment)
VERCEL_TOKEN=

# Netlify Token (for deployment)
NETLIFY_TOKEN=

# =============================================================================
# Tool Integrations
# =============================================================================

# Stability AI (Stable Diffusion)
EMPIREOS_STABILITY_API_KEY=

# Runway (video generation)
EMPIREOS_RUNWAY_API_KEY=

# Pika (video generation)
EMPIREOS_PIKA_API_KEY=

# Perplexity (web search)
EMPIREOS_PERPLEXITY_API_KEY=

# ComfyUI server
EMPIREOS_COMFYUI_URL=http://localhost:8188

# =============================================================================
# Authentication
# =============================================================================

# API key for securing the backend (generate a strong random key)
EMPIREOS_API_KEY=dev-key-change-in-production

# =============================================================================
# Advanced
# =============================================================================

# Maximum upload size (bytes)
EMPIREOS_MAX_UPLOAD_SIZE=104857600

# Request timeout (seconds)
EMPIREOS_REQUEST_TIMEOUT=120

# WebSocket ping interval (seconds)
EMPIREOS_WS_PING_INTERVAL=30

# Cache directory
EMPIREOS_CACHE_DIR=./cache

# Upload directory
EMPIREOS_UPLOAD_DIR=./uploads
